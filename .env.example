# Copy to .env for local dev. In production set these as GitHub Actions
# repository secrets (Settings → Secrets and variables → Actions).

# --- AI providers --------------------------------------------------------
# Anthropic Claude — writes the blog post body. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenAI — generates the hero image. https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# --- Website repo target -------------------------------------------------
# Where the agent commits new blog posts. This is the AI Separations site repo.
WEBSITE_REPO=danelas/color-sep-program

# Branch Vercel deploys from
WEBSITE_BRANCH=main

# Fine-grained Personal Access Token with "Contents: Read and write" on the
# WEBSITE_REPO. Create at https://github.com/settings/tokens (fine-grained),
# scope it to danelas/color-sep-program only.
WEBSITE_REPO_TOKEN=github_pat_REPLACE_ME

# Commit author. The email MUST be tied to a real GitHub account or Vercel
# refuses to deploy the commit (so the post never goes live).
GIT_AUTHOR_NAME=AI Separations Blog
GIT_AUTHOR_EMAIL=danamazon6@gmail.com

# Copy to .env for local dev. In production set these as GitHub Actions secrets.

# --- AI providers (reuse the same keys as the blog agent) ---------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME      # Claude — writes the caption + image prompt
OPENAI_API_KEY=sk-REPLACE_ME             # gpt-image-1 — generates the post image

# --- Upload-Post (multi-platform publisher) ----------------------------
# Get these from https://www.upload-post.com — create a profile, connect your
# Instagram / TikTok / Facebook / YouTube accounts to it, then copy:
UPLOAD_POST_API_KEY=REPLACE_ME           # dashboard API key
UPLOAD_POST_USER=AISeparations           # the profile name that has the accounts connected

# Optional safety check — abort if the connected handles don't match, so posts
# never land on the wrong account. Format: platform:handle,platform:handle
# UPLOAD_POST_EXPECTED_HANDLES=instagram:aiseparations,tiktok:aiseparations,facebook:AI Separations
